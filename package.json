{
  "name": "receipt-scanner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "NODE_OPTIONS=--no-experimental-webstorage vitest run",
    "test:watch": "NODE_OPTIONS=--no-experimental-webstorage vitest",
    "test:ui": "NODE_OPTIONS=--no-experimental-webstorage vitest --ui",
    "test:coverage": "NODE_OPTIONS=--no-experimental-webstorage vitest run --coverage"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "jsdom": "^28.1.0",
    "pdf-lib": "^1.17.1",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vite-plugin-mkcert": "^1.17.10",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "serialize-javascript": ">=7.0.3"
  },
  "dependencies": {
    "pdfjs-dist": "^5.5.207",
    "tesseract.js": "^7.0.0"
  }
}
